{
	"name": "@beaugmented/agency",
	"version": "0.1.0",
	"license": "MIT",
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/beaugmented/agency.git",
		"directory": "packages/agency"
	},
	"packageManager": "pnpm@10.33.0",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"module": "dist/index.js",
	"files": [
		"dist",
		"src",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "tsdown",
		"lint:biome": "biome check -- .",
		"lint:eslint": "eslint -- .",
		"lint:types": "tsc --noEmit",
		"lint": "bun run lint:biome && bun run lint:eslint && bun run lint:types",
		"test": "vitest",
		"test:once": "vitest run",
		"test:coverage": "echo no test coverage yet",
		"test:semver": "bun run build && bun run test:once"
	},
	"devDependencies": {
		"@types/node": "24.12.2",
		"@types/tmp": "0.2.6",
		"break-check": "0.6.26",
		"concurrently": "9.2.1",
		"eslint": "10.2.0",
		"openai": "6.34.0",
		"tmp": "0.2.5",
		"tsdown": "0.21.9",
		"typescript": "6.0.2",
		"vite": "8.0.8",
		"vitest": "4.1.4",
		"zod": "4.3.6"
	},
	"dependencies": {
		"atom.io": "0.46.33",
		"varmint": "0.5.13"
	}
}
